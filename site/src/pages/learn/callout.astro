const seo = "<title>วิธีทำกล่อง Callout (Note / Tip / Warning) ในบทความ Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/callout\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/callout\">\n<meta name=\"description\" content=\"วิธีเพิ่มกล่อง Callout (หมายเหตุ เคล็ดลับ สำเร็จ คำเตือน ข้อควรระวัง ดาวน์โหลด) ในธีม Blogger ด้วย BlogKub มี 6 แบบพร้อมไอคอนและสี วางในโพสต์ด้วยคลาส .bk-note ฯลฯ พร้อมวิธีใช้และแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำกล่อง Callout (Note / Tip / Warning) ในบทความ Blogger\">\n<meta property=\"og:description\" content=\"กล่องเน้นข้อความ 6 แบบพร้อมไอคอนและสี วางในโพสต์ด้วยคลาสง่าย ๆ\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/callout.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/callout.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\", \"url\": \"https://www.blogkub.com/\" },\n    { \"@type\": \"WebSite\", \"@id\": \"https://www.blogkub.com/#website\", \"url\": \"htt