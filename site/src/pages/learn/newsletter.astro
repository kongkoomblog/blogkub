const seo = "<title>วิธีทำกล่องรับอีเมล Newsletter (สมัครสมาชิก) ในบล็อก Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/newsletter\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/newsletter\">\n<meta name=\"description\" content=\"วิธีเพิ่มกล่องรับอีเมล Newsletter (สมัครรับบทความใหม่) ในธีม Blogger ด้วย BlogKub ตั้งหัวข้อ คำโปรย ปุ่ม และพื้นหลังได้ ต่อกับบริการอีเมลได้ ช่วยสร้างฐานผู้อ่านประจำ พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำกล่องรับอีเมล Newsletter (สมัครสมาชิก) ในบล็อก Blogger\">\n<meta property=\"og:description\" content=\"กล่องรับอีเมลสมัครรับบทความใหม่ ตั้งหัวข้อและปุ่มได้ สร้างฐานผู้อ่านประจำ\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/newsletter.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/newsletter.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\", \"url\": \"https://www.blogkub.com/\" },\n    { \"@type\": \"WebSite\", \"@id\": \"https://www.blogku