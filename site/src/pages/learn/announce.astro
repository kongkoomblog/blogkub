const seo = "<title>วิธีทำแถบประกาศด้านบน (Announcement Bar) ปิดได้ ใน Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/announce\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/announce\">\n<meta name=\"description\" content=\"วิธีเพิ่มแถบประกาศด้านบนสุด (Announcement Bar) ในธีม Blogger ด้วย BlogKub ใส่ข้อความ ลิงก์ CTA เลือกสีพื้น ผู้อ่านกดปิดได้และจำว่าปิดแล้ว เหมาะประกาศโปรโมชันหรือข่าวสาร พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำแถบประกาศด้านบน (Announcement Bar) ปิดได้ ใน Blogger\">\n<meta property=\"og:description\" content=\"แถบประกาศด้านบนสุด ใส่ข้อความและลิงก์ ผู้อ่านกดปิดได้และจำว่าปิดแล้ว\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/announce.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/announce.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\", \"url\": \"https://www.blogkub.com/\" },\n    { \"@type\": \"WebSite\", \"@id\": \"https://www.blogkub.com/#website