const head = "<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>วิธีทำ Sidebar (ไซด์บาร์) เนื้อหา + แถบข้าง ในธีม Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/sidebar\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/sidebar\">\n<meta name=\"description\" content=\"วิธีเพิ่ม Sidebar (ไซด์บาร์) ในธีม Blogger ด้วย BlogKub วางเนื้อหาหลักคู่กับแถบข้าง เลือกฝั่งซ้าย/ขวา ตั้งความกว้าง ใส่ช่องค้นหา หมวดหมู่ คลังบทความ และเกี่ยวกับผู้เขียน ระบบจัดวางอัตโนมัติ พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำ Sidebar (ไซด์บาร์) เนื้อหา + แถบข้าง ในธีม Blogger\">\n<meta property=\"og:description\" content=\"วางเนื้อหาคู่กับแถบข้าง เลือกฝั่งและความกว้าง ใส่ค้นหา หมวดหมู่ คลังบทความ เกี่ยวกับ\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/sidebar.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/sidebar.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name