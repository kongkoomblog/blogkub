const seo = "<title>วิธีทำบทความเด่น Featured (ปักหมุดข่าวเด่น) ใน Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/featured\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/featured\">\n<meta name=\"description\" content=\"วิธีตั้งค่าบทความเด่น Featured ในธีม Blogger ด้วย BlogKub ปักหมุดบทความแนะนำด้วยป้ายกำกับ แสดงเป็นข่าวเด่นใหญ่บนหน้าแรก ถ้าไม่มีก็ใช้บทความล่าสุดอัตโนมัติ ดึงจากฟีด พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำบทความเด่น Featured (ปักหมุดข่าวเด่น) ใน Blogger\">\n<meta property=\"og:description\" content=\"ปักหมุดบทความแนะนำด้วยป้ายกำกับ แสดงเป็นข่าวเด่นใหญ่บนหน้าแรก ดึงจากฟีด\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/featured.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/featured.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\", \"url\": \"https://www.blogkub.com/\" },\n    { \"@type\": \"WebSite\", \"@id\": \"https://www.blogkub.com/#website\", \"url