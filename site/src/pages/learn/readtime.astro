const head = "<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>วิธีทำเวลาในการอ่าน (Reading Time) บนการ์ดและบทความ Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/readtime\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/readtime\">\n<meta name=\"description\" content=\"วิธีเพิ่มเวลาในการอ่าน (Reading Time) ‘⏱ X นาที’ บนการ์ดหน้าแรกและในบทความธีม Blogger ด้วย BlogKub คำนวณอัตโนมัติจากเนื้อหา รองรับภาษาไทย ดึงผ่าน Feed แคช 12 ชม. พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำเวลาในการอ่าน (Reading Time) บนการ์ดและบทความ Blogger\">\n<meta property=\"og:description\" content=\"แสดง ‘⏱ X นาที’ บนการ์ดและในบทความ คำนวณอัตโนมัติ รองรับภาษาไทย\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/readtime.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/readtime.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\", \"url\": \"https://www.b