const head = "<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>วิธีทำบล็อกบทความล่าสุด/สุ่มบทความ (Recent & Random Posts) ใน Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/morefrom\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/morefrom\">\n<meta name=\"description\" content=\"วิธีเพิ่มส่วนบทความล่าสุดหรือสุ่มบทความ (Recent / Random Posts) ในธีม Blogger ด้วย BlogKub ดึงจากฟีดอัตโนมัติ กรองตามป้ายกำกับได้ พร้อมรูป หัวข้อ และวันที่ ช่วยให้ผู้อ่านอ่านต่อ พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำบล็อกบทความล่าสุด/สุ่มบทความ (Recent & Random Posts) ใน Blogger\">\n<meta property=\"og:description\" content=\"ดึงบทความล่าสุดหรือสุ่มจากฟีดอัตโนมัติ กรองตามป้ายกำกับ ช่วยให้ผู้อ่านอ่านต่อ\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/morefrom.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/morefrom.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\