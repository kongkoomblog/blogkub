"@type\": \"WebSite\", \"@id\": \"https://www.blogkub.com/#website\", \"url\": \"https://www.blogkub.com/\", \"name\": \"BlogKub\", \"publisher\": { \"@id\": \"https://www.blogkub.com/#org\" }, \"inLanguage\": \"th\" },\n    { \"@type\": \"BreadcrumbList\", \"itemListElement\": [\n      { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"หน้าแรก\", \"item\": \"https://www.blogkub.com/\" },\n      { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"เรียนรู้\", \"item\": \"https://www.blogkub.com/learn/\" },\n      { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"สารบัญอัตโนมัติ (TOC)\" }\n    ]},\n    {\n      \"@type\": \"HowTo\",\n      \"name\": \"วิธีเพิ่มสารบัญอัตโนมัติ (Table of Contents) ในธีม Blogger ด้วย BlogKub\",\n      \"description\": \"ขั้นตอนการเพิ่มและตั้งค่าสารบัญที่สร้างจากหัวข้อ H2/H3 โดยอัตโนมัติ แล้ว Export เป็น Blogger XML\",\n      \"inLanguage\": \"th\",\n      \"totalTime\": \"PT5M\",\n      \"tool\": [{ \"@type\": \"HowToTool\", \"name\": \"BlogKub\" }, { \"@type\": \"HowToTool\", \"name\": \"บัญชี Blogger\" }],\n      \"step\": [\n        { \"@type\": \"HowToStep\", \"position\": 1, \"name\": \"เปิด BlogKub และเลือกเทมเพลต\", \"text\": \"เปิด BlogKub แล้วเลือกเทมเพลตที่ต้องการ เทมเพลตส่วนใหญ่ติดตั้งบล็อกสารบัญให้อัตโนมัติอยู่แล้ว\", \"url\": \"https://www.blogkub.com/learn/toc#step1\" },\n        { \"@type\": \"HowToStep\", \"position\": 2, \"name\": \"เพิ่มบล็อกสารบัญ\", \"text\": \"ถ้ายังไม่มี ให้ลากบล็อก ‘สารบัญ (TOC)’ จากคลังหมวดบทความ & UX เข้ามาในหน้า\", \"url\": \"https://www.blogkub.com/learn/toc#step2\" },\n        { \"@type\": \"HowToStep\", \"position\": 3, \"name\": \"ตั้งค่าสารบัญ\", \"text\": \"คลิกที่บล็อกเพื่อตั้งชื่อหัวข้อสารบัญ ความลึกของหัวข้อ (H2 หรือ H2+H3) และเปิด/ปิดการใส่เลขลำดับ\", \"url\": \"https://www.blogkub.com/learn/toc#step3\" },\n        { \"@type\": \"HowToStep\", \"position\": 4, \"name\": \"Export XML และอัปโหลด\", \"text\": \"กด Export XML แล้วอัปโหลดเข้า Blogger ผ่านเมนู ธีม → กู้คืน/สำรอ