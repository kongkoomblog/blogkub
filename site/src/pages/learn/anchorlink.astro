const head = "<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>วิธีทำลิงก์หัวข้อ (Anchor Link) คัดลอกลิงก์ไปยังหัวข้อ ใน Blogger 2026</title>\n<link rel=\"canonical\" href=\"https://www.blogkub.com/learn/anchorlink\">\n<meta property=\"og:url\" content=\"https://www.blogkub.com/learn/anchorlink\">\n<meta name=\"description\" content=\"วิธีเพิ่มลิงก์หัวข้อ (Anchor Link) ในธีม Blogger ด้วย BlogKub ให้ผู้อ่านกดคัดลอกลิงก์ตรงไปยังหัวข้อ H2/H3 ที่ต้องการได้ ระบบสร้าง id อัตโนมัติ รองรับภาษาไทย พร้อมวิธีตั้งค่าและแก้ปัญหา\">\n<meta name=\"robots\" content=\"index,follow,max-image-preview:large,max-snippet:-1\">\n<meta property=\"og:type\" content=\"article\">\n<meta property=\"og:title\" content=\"วิธีทำลิงก์หัวข้อ (Anchor Link) คัดลอกลิงก์ไปยังหัวข้อ ใน Blogger\">\n<meta property=\"og:description\" content=\"ให้ผู้อ่านกดคัดลอกลิงก์ตรงไปยังหัวข้อที่ต้องการ แชร์จุดที่แม่นยำในบทความยาว\">\n<meta property=\"og:locale\" content=\"th_TH\">\n<meta name=\"twitter:card\" content=\"summary_large_image\">\n<meta property=\"og:image\" content=\"https://www.blogkub.com/learn/og/anchorlink.png\">\n<meta property=\"og:image:width\" content=\"1200\">\n<meta property=\"og:image:height\" content=\"630\">\n<meta name=\"twitter:image\" content=\"https://www.blogkub.com/learn/og/anchorlink.png\">\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#org\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n    { \"@type\": \"Organization\", \"@id\": \"https://www.blogkub.com/#org\", \"name\": \"BlogKub\