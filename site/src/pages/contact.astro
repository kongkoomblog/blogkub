---
import SiteLayout from '../layouts/SiteLayout.astro';
const meta = {"title": "ติดต่อเรา — BlogKub เครื่องมือแต่งธีม Blogger", "description": "ติดต่อทีมงาน BlogKub สอบถาม แจ้งปัญหา หรือเสนอแนะฟีเจอร์ เรายินดีรับฟังทุกความคิดเห็นเพื่อพัฒนาเครื่องมือแต่งธีม Blogger ให้ดียิ่งขึ้น", "canonical": "https://www.blogkub.com/contact", "ogType": "website", "ogTitle": "ติดต่อเรา — BlogKub", "ogDescription": "สอบถาม แจ้งปัญหา หรือเสนอแนะฟีเจอร์กับทีมงาน BlogKub", "ogUrl": "https://www.blogkub.com/contact", "ogImage": "https://www.blogkub.com/android-chrome-512x512.png", "twitterCard": "summary"};
const schema = "{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":\"Organization\",\"@id\":\"https://www.blogkub.com/#organization\",\"name\":\"BlogKub\",\"url\":\"https://www.blogkub.com/\",\"email\":\"hello@blogkub.com\"},\n{\"@type\":\"ContactPage\",\"@id\":\"https://www.blogkub.com/contact#webpage\",\"url\":\"https://www.blogkub.com/contact\",\"name\":\"ติดต่อเรา — BlogKub\",\"inLanguage\":\"th\",\"isPartOf\":{\"@id\":\"https://www.blogkub.com/#website\"}},\n{\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"หน้าแรก\",\"item\":\"https://www.blogkub.com/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"ติดต่อเรา\"}]}\n]}";
const article = "<main class=\"wrap\"><article class=\"doc\">\n<nav class=\"crumb\"><a href=\"/\">หน้าแรก</a> › <span>ติดต่อเรา</span></nav>\n<span class=\"pill\">ติดต่อเรา</span>\n<h1>มีคำถาม หรืออยาก <span class=\"g\">เสนอแนะฟีเจอร์</span>?</h1>\n<p class=\"lead\">เรายินดีรับฟังทุกความคิดเห็นเสมอ ไม่ว่าจะเป็นการสอบถามวิธีใช้งาน แจ้งปัญหาที่พบ เสนอไอเดียฟีเจอร์ใหม่ หรือพูดคุยเรื่องความร่วมมือ ทีมงาน BlogKub อ่านทุกข้อความและตั้งใจตอบกลับให้เร็วที่สุด</p>\n\n<div class=\"channels\">\n  <div class=\"ch\"><div class=\"ic\">✉️</div><b>อีเมล</b><a href=\"mailto:hello@blogkub.com\">hello@blogkub.com</a></div>\n  <div class=\"ch\"><div class=\"ic\">💬</div><b>Facebook</b><a href=\"https://www.facebook.com/patpisan\" target=\"_blank\" rel=\"noopener\">ผู้ก่อตั้ง (เบน)</a></div>\n  <div class=\"ch\"><div class=\"ic\">🗨️</div><b>Pantip</b><a href=\"https://pantip.com/profile/2448725\" target=\"_blank\" rel=\"noopener\">LuMoo (ลูโม)</a></div>\n  <div class=\"ch\"><div class=\"ic\">📚</div><b>ศูนย์เรียนรู้</b><a href=\"/learn/\">อ่านคู่มือการใช้งาน</a></div>\n  <div class=\"ch\"><div class=\"ic\">🛠️</div><b>ลองใช้เครื่องมือ</b><a href=\"/builder\">เปิด BlogKub Builder</a></div>\n</div>\n\n<h2>เรื่องที่ติดต่อเราได้</h2>\n<ul>\n  <li><strong>สอบถามการใช้งาน</strong> — ไม่แน่ใจว่าฟีเจอร์ไหนทำงานอย่างไร หรือทำสิ่งที่ต้องการได้ไหม</li>\n  <li><strong>แจ้งปัญหา (bug)</strong> — พบข้อผิดพลาด ไฟล์ที่ export มีปัญหา หรือการแสดงผลผิดเพี้ยน</li>\n  <li><strong>เสนอฟีเจอร์</strong> — อยากให้ BlogKub มีบล็อก เทมเพลต หรือความสามารถใหม่ ๆ</li>\n  <li><strong>ความร่วมมือและอื่น ๆ</strong> — สอบถามเรื่องการใช้งานร่วมกัน สื่อ หรือข้อเสนอแนะทั่วไป</li>\n</ul>\n\n<h2>ก่อนติดต่อ ลองดูสิ่งเหล่านี้ก่อน</h2>\n<p>คำถามการใช้งานส่วนใหญ่มีคำตอบอยู่แล้วใน <a href=\"/learn/\">ศูนย์เรียนรู้</a> ซึ่งรวมคู่มือทีละฟีเจอร์พร้อมภาพประกอบและวิธีทำทีละขั้น เช่น <a href=\"/learn/toc\">สารบัญอัตโนมัติ</a>, <a href=\"/learn/dark-mode\">โหมดมืด</a>, <a href=\"/learn/aeo\">กล่องสรุป AEO</a> และ <a href=\"/learn/templates\">การเลือกเทมเพลต</a> ส่วนบทความเชิงลึกเรื่องการทำบล็อกให้ติดหน้าแรก Google และการหารายได้ อ่านได้ที่ <a href=\"/blog/\">บล็อกของเรา</a></p>\n\n<h2>เวลาในการตอบกลับ</h2>\n<p>BlogKub ดูแลโดยทีมเล็ก เราอ่านทุกข้อความและตั้งใจตอบกลับภายในเวลาที่เหมาะสม แต่บางครั้งอาจใช้เวลาสักหน่อยในช่วงที่มีคำถามเข้ามาก การอธิบายปัญหาให้ชัดเจน (พร้อมภาพหน้าจอถ้ามี) จะช่วยให้เราช่วยคุณได้เร็วขึ้น</p>\n\n<div class=\"note\">ขอบคุณที่ใช้งานและสนับสนุน BlogKub ทุกความคิดเห็นของคุณคือแรงผลักดันให้เราพัฒนาเครื่องมือให้ดีขึ้นเรื่อย ๆ ครับ</div>\n</article></main>";
---
<SiteLayout {...meta} schema={schema}>
  <Fragment set:html={article} />
</SiteLayout>
