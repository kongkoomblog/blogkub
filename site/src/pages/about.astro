---
import SiteLayout from '../layouts/SiteLayout.astro';
const meta = {"title": "เกี่ยวกับ BlogKub — เครื่องมือแต่งธีม Blogger ฟรี ไม่ต้องเขียนโค้ด", "description": "BlogKub คือเครื่องมือสร้างและตกแต่งธีม Blogger ที่ทำงานในเบราว์เซอร์ 100% ใช้ฟรี ไม่ต้องเขียนโค้ด รู้จักที่มา แนวคิด และสิ่งที่เราตั้งใจสร้างเพื่อคนทำบล็อกไทย", "canonical": "https://www.blogkub.com/about", "ogType": "website", "ogTitle": "เกี่ยวกับ BlogKub — เครื่องมือแต่งธีม Blogger ฟรี", "ogDescription": "รู้จักที่มา แนวคิด และสิ่งที่ BlogKub ตั้งใจสร้างเพื่อคนทำบล็อก Blogger", "ogUrl": "https://www.blogkub.com/about", "ogImage": "https://www.blogkub.com/android-chrome-512x512.png", "twitterCard": "summary"};
const schema = "{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":\"Organization\",\"@id\":\"https://www.blogkub.com/#organization\",\"name\":\"BlogKub\",\"url\":\"https://www.blogkub.com/\",\"description\":\"เครื่องมือสร้างและตกแต่งธีม Blogger แบบ no-code ทำงานฝั่งผู้ใช้ 100%\",\"founder\":{\"@id\":\"https://www.blogkub.com/#patpisan\"}},\n{\"@type\":\"Person\",\"@id\":\"https://www.blogkub.com/#patpisan\",\"name\":\"ภัทร์พิศาล ดาทอง\",\"alternateName\":[\"PATPISAN DATHONG\",\"เบน\",\"LuMoo\"],\"url\":\"https://www.blogkub.com/about\",\"image\":\"https://www.blogkub.com/author-patpisan.png\",\"jobTitle\":\"ผู้ก่อตั้งและผู้เขียน BlogKub\",\"worksFor\":{\"@id\":\"https://www.blogkub.com/#organization\"},\"sameAs\":[\"https://www.facebook.com/patpisan\",\"https://pantip.com/profile/2448725\"]},\n{\"@type\":\"AboutPage\",\"@id\":\"https://www.blogkub.com/about#webpage\",\"url\":\"https://www.blogkub.com/about\",\"name\":\"เกี่ยวกับ BlogKub\",\"inLanguage\":\"th\",\"isPartOf\":{\"@id\":\"https://www.blogkub.com/#website\"},\"about\":{\"@id\":\"https://www.blogkub.com/#organization\"}},\n{\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"หน้าแรก\",\"item\":\"https://www.blogkub.com/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"เกี่ยวกับเรา\"}]}\n]}";
const article = "<main class=\"wrap\"><article class=\"doc\">\n<nav class=\"crumb\"><a href=\"/\">หน้าแรก</a> › <span>เกี่ยวกับเรา</span></nav>\n<span class=\"pill\">เกี่ยวกับเรา</span>\n<h1>สร้างธีม Blogger ให้ <span class=\"g\">ทุกคนทำเองได้</span> โดยไม่ต้องเขียนโค้ด</h1>\n<p class=\"lead\">BlogKub คือเครื่องมือช่วยสร้างและตกแต่งธีม (template) สำหรับ Blogger ที่ทำงานในเบราว์เซอร์ทั้งหมด ใช้ฟรี ไม่ต้องสมัครสมาชิก และไม่ต้องมีพื้นฐานการเขียนโค้ด เราตั้งใจให้คนทำบล็อกทุกคน—ตั้งแต่มือใหม่จนถึงมืออาชีพ—มีเว็บที่สวย เร็ว และทำ SEO ได้จริง โดยไม่ต้องยุ่งกับไฟล์ XML ที่ซับซ้อนหรือจ้างนักพัฒนา</p>\n\n<h2>BlogKub คืออะไร</h2>\n<p>Blogger เป็นแพลตฟอร์มทำบล็อกฟรีที่ทรงพลัง แต่การปรับแต่งธีมให้สวยและทำ SEO ให้ถูกต้องมักต้องยุ่งกับไฟล์ XML ที่ซับซ้อน ซึ่งเป็นกำแพงสำหรับคนทั่วไป <strong>BlogKub เกิดขึ้นเพื่อทลายกำแพงนั้น</strong> ด้วยการให้คุณประกอบหน้าเว็บจาก “บล็อก” ที่ลากวางได้ ปรับข้อความ สี ฟอนต์ และเปิด/ปิดฟีเจอร์ต่าง ๆ แล้วกดดาวน์โหลดเป็นไฟล์ Blogger XML ที่พร้อมอัปโหลดใช้งานจริง</p>\n\n<h2>สิ่งที่เราเชื่อ</h2>\n<div class=\"grid\">\n  <div class=\"card\"><strong>ฟรีและเข้าถึงง่าย</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">เครื่องมือที่ดีไม่ควรมีราคาเป็นกำแพง ทุกคนควรทำเว็บสวย ๆ ได้</p></div>\n  <div class=\"card\"><strong>ความเป็นส่วนตัวมาก่อน</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">ทำงานฝั่งผู้ใช้ 100% ข้อมูลโปรเจกต์อยู่ในเบราว์เซอร์ของคุณ ไม่ถูกส่งขึ้นเซิร์ฟเวอร์</p></div>\n  <div class=\"card\"><strong>คุณภาพระดับมืออาชีพ</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">ธีมมาพร้อมโครงสร้าง SEO, Schema และความเร็วที่ถูกหลักตั้งแต่แกะกล่อง</p></div>\n</div>\n\n<h2>ทำงานอย่างไร</h2>\n<p>ทุกอย่างเกิดขึ้นในเบราว์เซอร์ของคุณเอง เราไม่มีการอัปโหลดข้อมูลขึ้นเซิร์ฟเวอร์ ขั้นตอนใช้งานง่ายเพียงไม่กี่ขั้น</p>\n<ul>\n  <li><strong>เลือกเทมเพลต</strong> ที่ตรงกับแนวเว็บของคุณ ระบบติดตั้งบล็อกและฟีเจอร์ที่จำเป็นให้อัตโนมัติ</li>\n  <li><strong>ปรับแต่ง</strong> ข้อความ รูป สี ฟอนต์ และจัดลำดับบล็อกด้วยการลากวาง</li>\n  <li><strong>ดาวน์โหลด XML</strong> แล้วนำไปอัปโหลดเข้า Blogger ผ่านเมนู ธีม → กู้คืน/สำรอง</li>\n</ul>\n<p>อยากเห็นว่าแต่ละฟีเจอร์ทำงานอย่างไร ดูคู่มือละเอียดได้ที่ <a href=\"/learn/\">ศูนย์เรียนรู้ BlogKub</a> ซึ่งมีบทความสอนทีละฟีเจอร์พร้อมภาพประกอบ</p>\n\n<h2>ปรับแต่งเมนูได้ทุกจุด โดยไม่ต้องแตะโค้ด</h2>\n<p>เมนูคือหัวใจของการนำทางในเว็บ แต่บน Blogger การจัดการเมนูให้สวยและใช้งานง่ายมักต้องแก้ XML เอง <strong>BlogKub ทำให้เรื่องนี้กลายเป็นแค่การคลิกและพิมพ์</strong> คุณเพิ่ม ลบ เปลี่ยนชื่อ หรือจัดลำดับเมนูได้เองทั้งหมด เพียงลากวางและพิมพ์ข้อความ ไม่ต้องรู้จักโค้ดแม้แต่บรรทัดเดียว และทุกอย่างจะถูกแปลงเป็นธีมที่พร้อมใช้งานให้อัตโนมัติ</p>\n<p>ที่สำคัญคือเมนูถูกออกแบบมาให้ <strong>ดูดีและใช้ง่ายทุกขนาดหน้าจอ</strong> ระบบจะจัดวางเลย์เอาต์ให้เหมาะกับอุปกรณ์ของผู้อ่านโดยอัตโนมัติ ทั้งเวอร์ชันคอมพิวเตอร์และมือถือ</p>\n<div class=\"grid\">\n  <div class=\"card\"><strong>🖥️ เมนูเวอร์ชันเดสก์ท็อป</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">แถบเมนูแนวนอนเต็มความกว้าง วางเมนูได้ทั้งฝั่งซ้ายและฝั่งขวา จัดวางโลโก้ ลิงก์ และปุ่มต่าง ๆ ได้อย่างสมดุล</p></div>\n  <div class=\"card\"><strong>📱 เมนูเวอร์ชันมือถือ</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">ยุบเป็นปุ่มเมนู (hamburger) พร้อมแผงเมนูที่เลื่อนออกมาจากด้านข้าง ซ้ายหรือขวาก็ได้ แตะง่าย ไม่บังเนื้อหา</p></div>\n  <div class=\"card\"><strong>⬇️ เมนูล่างบนมือถืออัตโนมัติ</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">แถบนำทางด้านล่างจอ (bottom navigation) ปรากฏเองบนมือถือ ให้ผู้อ่านกดเมนูสำคัญได้ด้วยนิ้วโป้งอย่างเป็นธรรมชาติ</p></div>\n  <div class=\"card\"><strong>🗂️ รองรับเมนูย่อย</strong><p style=\"color:var(--ink-2);font-size:15px;margin:.4em 0 0\">สร้างเมนูแบบมีเมนูย่อย (dropdown/submenu) เพื่อจัดหมวดหมู่เนื้อหาเป็นชั้น ๆ ทำเว็บที่มีหลายหมวดให้ยังคงเป็นระเบียบ</p></div>\n</div>\n<p>ทั้งหมดนี้ตั้งค่าได้จากที่เดียวใน Builder แล้ว BlogKub จะดูแลเรื่องการแสดงผลบนแต่ละอุปกรณ์ให้เอง คุณจึงได้เมนูที่ทั้งสวย เข้ากันกับธีม และใช้งานได้จริงตั้งแต่ครั้งแรก โดยไม่ต้องเสียเวลากับโค้ดเลยแม้แต่นิดเดียว</p>\n\n<h2>ใครเหมาะกับ BlogKub</h2>\n<p>ตั้งแต่มือใหม่ที่เพิ่งเริ่มทำบล็อก ไปจนถึงคนที่อยากได้เว็บ Blogger ที่ดูมืออาชีพและทำ SEO ได้จริง โดยไม่ต้องจ้างนักพัฒนา ไม่ว่าจะเป็นบล็อกส่วนตัว บล็อกท่องเที่ยว รีวิวสินค้า คอร์สออนไลน์ หรือเว็บบริษัท BlogKub มีเทมเพลตและฟีเจอร์ให้เลือกใช้อย่างครบถ้วน</p>\n\n<h2>พันธกิจของเรา</h2>\n<p>เราเชื่อว่าการมีพื้นที่ของตัวเองบนอินเทอร์เน็ตไม่ควรถูกจำกัดด้วยความรู้ด้านโค้ดหรืองบประมาณ พันธกิจของ BlogKub คือ<strong>ลดกำแพงทางเทคนิคของการทำเว็บให้เหลือน้อยที่สุด</strong> เพื่อให้คุณใช้เวลาไปกับสิ่งที่สำคัญจริง ๆ นั่นคือการสร้างเนื้อหาที่ดี ไม่ใช่การนั่งแก้โค้ด เราพัฒนาเครื่องมือและคู่มืออย่างต่อเนื่อง โดยยึดหลักว่าทุกฟีเจอร์ต้องใช้งานง่าย ได้มาตรฐาน และเป็นประโยชน์กับผู้ใช้จริง</p>\n\n<h2 id=\"author\">ผู้ก่อตั้ง BlogKub</h2>\n<div class=\"card\" style=\"display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap\">\n  <img src=\"/author-patpisan.png\" width=\"96\" height=\"96\" loading=\"lazy\" alt=\"ภัทร์พิศาล ดาทอง (เบน) ผู้ก่อตั้ง BlogKub\" style=\"width:96px;height:96px;border-radius:50%;flex:none;border:2px solid var(--brand)\">\n  <div style=\"flex:1;min-width:240px\">\n    <div style=\"font-family:var(--font-display);font-weight:700;font-size:20px\">ภัทร์พิศาล ดาทอง <span style=\"color:var(--ink-3);font-weight:500;font-size:16px\">· เบน (Ben) · PATPISAN DATHONG</span></div>\n    <p style=\"margin:.55em 0 .9em;color:var(--ink-2);line-height:1.75\">ผมชื่อเบนครับ เป็นคนทำเว็บและบล็อกเกอร์สาย Blogger มานานหลายปี ผมสร้าง BlogKub ขึ้นมาเพราะเชื่อว่าคนไทยทุกคนควรมีบล็อกที่สวยและทำ SEO ได้จริงโดยไม่ต้องเขียนโค้ดหรือเสียเงินจ้างนักพัฒนา คู่มือและบทความทุกชิ้นบนเว็บนี้ผมเรียบเรียงจากประสบการณ์ทำธีม ปรับแต่ง และทำ SEO บน Blogger ด้วยตัวเอง</p>\n    <div style=\"display:flex;gap:10px;flex-wrap:wrap;font-size:14px\">\n      <a href=\"https://www.facebook.com/patpisan\" rel=\"me noopener\" target=\"_blank\" style=\"padding:6px 14px;border:1px solid var(--border);border-radius:999px;text-decoration:none;color:var(--brand-2);font-weight:600\">Facebook</a>\n      <a href=\"https://pantip.com/profile/2448725\" rel=\"me noopener\" target=\"_blank\" style=\"padding:6px 14px;border:1px solid var(--border);border-radius:999px;text-decoration:none;color:var(--brand-2);font-weight:600\">Pantip · LuMoo (ลูโม)</a>\n    </div>\n  </div>\n</div>\n\n<p style=\"margin-top:26px\"><a href=\"/builder\" class=\"cta\">เริ่มใช้เครื่องมือฟรี →</a></p>\n</article></main>";
---
<SiteLayout {...meta} schema={schema}>
  <Fragment set:html={article} />
</SiteLayout>
