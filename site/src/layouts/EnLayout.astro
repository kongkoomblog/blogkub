---
import '../styles/article.css';
const { seo, thHref = '/' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="manifest" href="/site.webmanifest">
<Fragment set:html={seo} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="alternate" type="application/rss+xml" title="BlogKub RSS" href="https://www.blogkub.com/rss.xml">
<link rel="alternate" type="application/feed+json" title="BlogKub JSON Feed" href="https://www.blogkub.com/feed.json">
</head>
<body>
<div class="aura"><b></b><b></b><b></b></div>
<div class="content">

<div class="beta-bar" role="status">
  <span class="beta-pill">🧪 BETA</span>
  <span>This site is in active development and some features may still change</span>
</div>

<header id="hdr">
  <div class="wrap nav">
    <a class="brand" href="/en/">
      <span class="logo"><img src="/android-chrome-192x192.png" alt="BlogKub" style="width:100%;height:100%;object-fit:cover;display:block"></span>
      BlogKub
    </a>
    <nav class="nav-links">
      <a href="/en/">Home</a>
      <a href="/en/#templates">Templates</a>
      <a href="/builder.html">Builder</a>
      <a href="/en/learn/">Docs</a>
      <a href="/en/blog/">Blog</a>
    </nav>
    <div class="nav-right">
      <div class="lang" id="lang">
        <a class="on" style="cursor:default">EN</a>
        <a href={thHref} hreflang="th">TH</a>
      </div>
      <button class="icon-btn" id="themeBtn" aria-label="theme">
        <svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
      <a class="btn btn-ghost" href="/builder" title="Optional, keeps your work saved">Log in</a>
      <a class="btn btn-primary" href="/builder.html">Get started</a>
      <button class="icon-btn nav-toggle" id="navToggle" aria-label="menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>
<a id="top"></a>
<slot />
<footer id="blog">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <a class="brand" href="#top"><span class="logo"><img src="/android-chrome-192x192.png" alt="BlogKub" style="width:100%;height:100%;object-fit:cover;display:block"></span>BlogKub</a>
        <p>A free, open tool for building Blogger XML themes visually, 100% client-side.</p>
      </div>
      <div class="foot-col"><h5>Resources</h5><a href="/en/#templates">Templates</a><a href="/en/learn/">Documentation</a><a href="/builder">Builder</a><a href="/en/blog/">Blog</a></div>
      <div class="foot-col"><h5>Community</h5><a href="https://github.com/kongkoomblog/blogkub" target="_blank" rel="noopener">GitHub</a><a href="/en/learn/">Help</a><a href="/en/blog/">Roadmap</a><a href="https://github.com/kongkoomblog/blogkub/commits" target="_blank" rel="noopener">Changelog</a></div>
      <div class="foot-col"><h5>Legal</h5><a href="/en/about">About</a><a href="/en/privacy">Privacy</a><a href="/en/terms">Terms</a><a href="/en/contact">Contact</a></div>
    </div>
    <div class="foot-bottom">
      <p>© 2026 BlogKub. All rights reserved.</p>
      <div class="socials">
        <a href="https://github.com/kongkoomblog/blogkub" target="_blank" rel="noopener" aria-label="GitHub"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 00-3.2 19.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.3-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.8v2.6c0 .3.2.6.7.5A10 10 0 0012 2z"/></svg></a>
      </div>
    </div>
  </div>
</footer>
</div><!-- /content -->
<div class="drawer" id="drawer">
  <div class="scrim" data-close></div>
  <div class="panel">
    <div class="dhead">
      <span class="brand" style="font-size:15px"><span class="logo" style="width:30px;height:30px"><img src="/android-chrome-192x192.png" alt="BlogKub" style="width:100%;height:100%;object-fit:cover;display:block"></span>Menu</span>
      <button class="icon-btn" data-close aria-label="close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
    </div>
    <a href="/en/" data-close>Home</a>
    <a href="/en/#templates" data-close>Templates</a>
    <a href="/builder.html" data-close>Builder</a>
    <a href="/en/learn/" data-close>Docs</a>
    <a href="/en/blog/" data-close>Blog</a>
    <hr>
    <div class="lang" id="langDrawer" style="width:100%">
      <a href={thHref} hreflang="th" style="flex:1">ไทย</a>
      <a class="on" style="flex:1;cursor:default">English</a>
    </div>
    <a class="btn btn-ghost" href="/builder">Log in</a>
    <a class="btn btn-primary" href="/builder.html" data-close>Get started</a>
  </div>
</div>
<script is:inline>
var sun='<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>';
var moon='<path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"/>';
function applyTheme(t){document.documentElement.dataset.theme=t;var i=document.getElementById('themeIcon');if(i)i.innerHTML=t==='dark'?sun:moon;try{localStorage.setItem('bxb_theme',t)}catch(e){}}
applyTheme((function(){try{return localStorage.getItem('bxb_theme')}catch(e){}}())||'dark');
var tb=document.getElementById('themeBtn');if(tb)tb.addEventListener('click',function(){applyTheme(document.documentElement.dataset.theme==='dark'?'light':'dark')});
var dr=document.getElementById('drawer'),nt=document.getElementById('navToggle');
if(nt&&dr)nt.addEventListener('click',function(){dr.classList.add('open')});
if(dr)dr.addEventListener('click',function(e){if(e.target.matches('[data-close]')||e.target.closest('[data-close]'))dr.classList.remove('open')});
var hd=document.getElementById('hdr');if(hd)addEventListener('scroll',function(){hd.classList.toggle('scrolled',scrollY>10)},{passive:true});
</script>
</body>
</html>
