---
import '../styles/blog.css';
const { head } = Astro.props;
---
<!doctype html>
<html lang="th">
<head>
<Fragment set:html={head} />
<link rel="alternate" type="application/rss+xml" title="BlogKub RSS" href="https://www.blogkub.com/rss.xml">
<link rel="alternate" type="application/feed+json" title="BlogKub JSON Feed" href="https://www.blogkub.com/feed.json">
</head>
<body>
<header class="top">
  <div class="bar">
    <a class="brand" href="/"><span class="lg"><img src="/android-chrome-192x192.png" alt="BlogKub"></span>BlogKub</a>
    <nav>
      <a href="/">หน้าแรก</a><a href="/#templates">เทมเพลต</a><a href="/builder.html">Builder</a><a href="/learn/">เอกสาร</a><a href="/blog/" class="on">บล็อก</a>
    </nav>
  </div>
</header>
<slot />
<footer class="site">
  © 2026 BlogKub · <a href="/">หน้าแรก</a> · <a href="/blog/">บล็อก</a> · <a href="/learn/">เอกสาร</a> · <a href="/builder.html">Builder</a> · <a href="/about">เกี่ยวกับ</a> · <a href="/privacy">ความเป็นส่วนตัว</a>
</footer>
<script is:inline>(function(){try{var t=localStorage.getItem('bxb_theme');if(t)document.documentElement.dataset.theme=t;}catch(e){}}());</script>
</body>
</html>
