# Astro build assets are content-hashed -> safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: no-cache

/app.html
  Cache-Control: no-cache

/builder
  Cache-Control: no-cache

/builder.html
  Cache-Control: no-cache

/404.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

/th/*
  Cache-Control: no-cache

/en/*
  Cache-Control: no-cache

/learn/*
  Cache-Control: no-cache
