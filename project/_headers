# PRODUCTION caching headers (live).
# Static assets are cached hard for speed; HTML always revalidates so content
# edits appear immediately; feeds/sitemaps refresh hourly.

# --- Static assets: cache hard (screenshots, OG cards, logo, builder bundle) ---
/assets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/learn/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/learn/og/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/blog/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# --- Brand images / icons at the root ---
/og-home.png
  Cache-Control: public, max-age=604800
/og-home-en.png
  Cache-Control: public, max-age=604800
/author-patpisan.png
  Cache-Control: public, max-age=604800
/android-chrome-512x512.png
  Cache-Control: public, max-age=2592000
/android-chrome-192x192.png
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/favicon.ico
  Cache-Control: public, max-age=2592000
/favicon-32x32.png
  Cache-Control: public, max-age=2592000
/favicon-16x16.png
  Cache-Control: public, max-age=2592000
/site.webmanifest
  Cache-Control: public, max-age=604800

# --- Feeds, sitemaps, robots: refresh hourly ---
/rss.xml
  Cache-Control: public, max-age=3600
/feed.json
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/sitemap-images.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# --- Everything else (HTML pages): always revalidate so edits show instantly ---
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
